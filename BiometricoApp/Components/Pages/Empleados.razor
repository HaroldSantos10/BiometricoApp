@page "/empleados"
@using BiometricoApp.Models
@using BiometricoApp.Data
@using BiometricoApp.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject AppDbContext DB
@inject EmpleadoImportService ImportService
@rendermode InteractiveServer

<PageTitle>Gestión de Empleados</PageTitle>

<div style="padding: 1rem;">
    <h2>Gestión de Empleados</h2>

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem; flex-wrap:wrap;">
        <button @onclick="MostrarFormulario"
                style="padding:0.5rem 1rem; background:#1a73e8; color:white; border:none; border-radius:6px; cursor:pointer;">
            + Nuevo Empleado
        </button>

        <InputFile OnChange="ArchivoSeleccionado" accept=".csv" />

        @if (archivoListo)
        {
            <button @onclick="ProcesarArchivo"
                    style="padding:0.5rem 1rem; background:#34a853; color:white; border:none; border-radius:6px; cursor:pointer;">
                Procesar CSV
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensajeImport))
    {
        <p style="color:#1a73e8; margin-bottom:1rem;">@mensajeImport</p>
    }

    @if (previstaImport.Count > 0)
    {
        <div style="background:#f5f5f5; padding:1rem; border-radius:8px; margin-bottom:1.5rem;">
            <h4>Vista previa — @previstaImport.Count empleados detectados</h4>
            <p style="font-size:13px; color:#555;">Revisa los datos antes de confirmar.</p>
            <table style="width:100%; border-collapse:collapse; font-size:12px; overflow-x:auto; display:block;">
                <thead>
                    <tr style="background:#e8f0fe;">
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Nombre</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">DUI</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Departamento</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Cargo</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Contrato</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Género</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Teléfono</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Correo</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">Salario</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">F. Ingreso</th>
                        <th style="padding:6px; text-align:left; white-space:nowrap;">F. Nacimiento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in previstaImport)
                    {
                        <tr style="border-bottom:1px solid #ddd;">
                            <td style="padding:6px; white-space:nowrap;">@emp.Nombre</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.DUI</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.Departamento</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.Cargo</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.TipoContrato</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.Genero</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.Telefono</td>
                            <td style="padding:6px; white-space:nowrap;">@emp.Correo</td>
                            <td style="padding:6px; white-space:nowrap;">$@emp.Salario.ToString("N2")</td>
                            <td style="padding:6px; white-space:nowrap;">
                                @(emp.FechaIngreso == default ? "-" : emp.FechaIngreso.ToString("dd/MM/yyyy"))
                            </td>
                            <td style="padding:6px; white-space:nowrap;">
                                @(emp.FechaNacimiento == default ? "-" : emp.FechaNacimiento.ToString("dd/MM/yyyy"))
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div style="margin-top:1rem; display:flex; gap:0.5rem;">
                <button @onclick="ConfirmarImportCsv"
                        style="padding:0.5rem 1.5rem; background:#34a853; color:white; border:none; border-radius:6px; cursor:pointer;">
                    Confirmar importación (@previstaImport.Count empleados)
                </button>
                <button @onclick="() => { previstaImport.Clear(); mensajeImport = string.Empty; }"
                        style="padding:0.5rem 1.5rem; background:#ccc; border:none; border-radius:6px; cursor:pointer;">
                    Cancelar
                </button>
            </div>
        </div>
    }

    @if (mostrarForm)
    {
        <div style="background:#f5f5f5; padding:1.5rem; border-radius:8px; margin-bottom:1.5rem;">
            <h4>@(empleadoEditando.Id == 0 ? "Nuevo Empleado" : "Editar Empleado")</h4>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem;">
                <div>
                    <label>Código Empleado</label>
                    <input @bind="empleadoEditando.CodigoEmpleado" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Nombre completo</label>
                    <input @bind="empleadoEditando.Nombre" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>DUI</label>
                    <input @bind="empleadoEditando.DUI" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Correo</label>
                    <input @bind="empleadoEditando.Correo" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Teléfono</label>
                    <input @bind="empleadoEditando.Telefono" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Departamento</label>
                    <input @bind="empleadoEditando.Departamento" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Cargo</label>
                    <input @bind="empleadoEditando.Cargo" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Cargo Académico</label>
                    <input @bind="empleadoEditando.CargoAcademico" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Género</label>
                    <select @bind="empleadoEditando.Genero" style="width:100%; padding:0.4rem; margin-top:4px;">
                        <option value="">-- Seleccionar --</option>
                        <option value="M">Masculino</option>
                        <option value="F">Femenino</option>
                    </select>
                </div>
                <div>
                    <label>Tipo de Contrato</label>
                    <input @bind="empleadoEditando.TipoContrato" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Salario</label>
                    <input type="number" @bind="empleadoEditando.Salario" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Fecha de Ingreso</label>
                    <input type="date" value="@fechaIngresoStr"
                           @oninput="e => fechaIngresoStr = e.Value?.ToString() ?? string.Empty"
                           style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Fecha de Nacimiento</label>
                    <input type="date" value="@fechaNacimientoStr"
                           @oninput="e => fechaNacimientoStr = e.Value?.ToString() ?? string.Empty"
                           style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Dirección</label>
                    <input @bind="empleadoEditando.Direccion" style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
            </div>

            <hr style="margin:1rem 0;" />
            <h5>Horario de trabajo</h5>
            <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:1rem;">
                <div>
                    <label>Hora entrada (Lun-Vie)</label>
                    <input type="time" value="@horaEntradaStr"
                           @oninput="e => horaEntradaStr = e.Value?.ToString() ?? string.Empty"
                           style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div>
                    <label>Hora salida (Lun-Vie)</label>
                    <input type="time" value="@horaSalidaStr"
                           @oninput="e => horaSalidaStr = e.Value?.ToString() ?? string.Empty"
                           style="width:100%; padding:0.4rem; margin-top:4px;" />
                </div>
                <div style="display:flex; align-items:center; gap:8px; margin-top:1.5rem;">
                    <input type="checkbox" @bind="empleadoEditando.TrabajaSabado" id="sabado" />
                    <label for="sabado">Trabaja sábado</label>
                </div>
                @if (empleadoEditando.TrabajaSabado)
                {
                    <div>
                        <label>Hora entrada (Sábado)</label>
                        <input type="time" value="@horaEntradaSabadoStr"
                               @oninput="e => horaEntradaSabadoStr = e.Value?.ToString() ?? string.Empty"
                               style="width:100%; padding:0.4rem; margin-top:4px;" />
                    </div>
                    <div>
                        <label>Hora salida (Sábado)</label>
                        <input type="time" value="@horaSalidaSabadoStr"
                               @oninput="e => horaSalidaSabadoStr = e.Value?.ToString() ?? string.Empty"
                               style="width:100%; padding:0.4rem; margin-top:4px;" />
                    </div>
                }
            </div>

            <div style="margin-top:1rem; display:flex; gap:0.5rem;">
                <button @onclick="GuardarEmpleado"
                        style="padding:0.5rem 1.5rem; background:#1a73e8; color:white; border:none; border-radius:6px; cursor:pointer;">
                    Guardar
                </button>
                <button @onclick="CancelarFormulario"
                        style="padding:0.5rem 1.5rem; background:#ccc; border:none; border-radius:6px; cursor:pointer;">
                    Cancelar
                </button>
            </div>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <p style="color:green; margin-top:0.5rem;">@mensaje</p>
            }
        </div>
    }

    <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
            <tr style="background:#1a73e8; color:white;">
                <th style="padding:8px; text-align:left;">Código</th>
                <th style="padding:8px; text-align:left;">Nombre</th>
                <th style="padding:8px; text-align:left;">Departamento</th>
                <th style="padding:8px; text-align:left;">Cargo</th>
                <th style="padding:8px; text-align:left;">Entrada</th>
                <th style="padding:8px; text-align:left;">Salida</th>
                <th style="padding:8px; text-align:left;">Sábado</th>
                <th style="padding:8px; text-align:left;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in empleados)
            {
                <tr style="border-bottom:1px solid #ddd;">
                    <td style="padding:8px;">@emp.CodigoEmpleado</td>
                    <td style="padding:8px;">@emp.Nombre</td>
                    <td style="padding:8px;">@emp.Departamento</td>
                    <td style="padding:8px;">@emp.Cargo</td>
                    <td style="padding:8px;">@emp.HoraEntrada.ToString("HH:mm")</td>
                    <td style="padding:8px;">@emp.HoraSalida.ToString("HH:mm")</td>
                    <td style="padding:8px;">@(emp.TrabajaSabado ? "Sí" : "No")</td>
                    <td style="padding:8px;">
                        <button @onclick="() => EditarEmpleado(emp)"
                                style="padding:4px 10px; background:#f0a500; color:white; border:none; border-radius:4px; cursor:pointer; margin-right:4px;">
                            Editar
                        </button>
                        <button @onclick="() => EliminarEmpleado(emp.Id)"
                                style="padding:4px 10px; background:#e53935; color:white; border:none; border-radius:4px; cursor:pointer;">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Empleado> empleados = new();
    private Empleado empleadoEditando = new();
    private bool mostrarForm = false;
    private string mensaje = string.Empty;

    // Variables importación
    private List<Empleado> previstaImport = new();
    private bool importando = false;
    private bool archivoListo = false;
    private string mensajeImport = string.Empty;
    private IBrowserFile? archivoSeleccionado;

    private string horaEntradaStr
    {
        get => empleadoEditando.HoraEntrada.ToString("HH:mm");
        set { if (TimeOnly.TryParse(value, out var t)) empleadoEditando.HoraEntrada = t; }
    }
    private string horaSalidaStr
    {
        get => empleadoEditando.HoraSalida.ToString("HH:mm");
        set { if (TimeOnly.TryParse(value, out var t)) empleadoEditando.HoraSalida = t; }
    }
    private string horaEntradaSabadoStr
    {
        get => empleadoEditando.HoraEntradaSabado.ToString("HH:mm");
        set { if (TimeOnly.TryParse(value, out var t)) empleadoEditando.HoraEntradaSabado = t; }
    }
    private string horaSalidaSabadoStr
    {
        get => empleadoEditando.HoraSalidaSabado.ToString("HH:mm");
        set { if (TimeOnly.TryParse(value, out var t)) empleadoEditando.HoraSalidaSabado = t; }
    }
    private string fechaIngresoStr
    {
        get => empleadoEditando.FechaIngreso == default ? "" : empleadoEditando.FechaIngreso.ToString("yyyy-MM-dd");
        set { if (DateOnly.TryParse(value, out var d)) empleadoEditando.FechaIngreso = d; }
    }
    private string fechaNacimientoStr
    {
        get => empleadoEditando.FechaNacimiento == default ? "" : empleadoEditando.FechaNacimiento.ToString("yyyy-MM-dd");
        set { if (DateOnly.TryParse(value, out var d)) empleadoEditando.FechaNacimiento = d; }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
    }

    private async Task CargarEmpleados()
    {
        empleados = await DB.Empleados.Where(e => e.Activo).ToListAsync();
    }

    private void MostrarFormulario()
    {
        empleadoEditando = new Empleado();
        mostrarForm = true;
        mensaje = string.Empty;
    }

    private void CancelarFormulario()
    {
        mostrarForm = false;
        mensaje = string.Empty;
    }

    private async Task GuardarEmpleado()
    {
        if (empleadoEditando.Id == 0)
            DB.Empleados.Add(empleadoEditando);
        else
            DB.Empleados.Update(empleadoEditando);

        await DB.SaveChangesAsync();
        await CargarEmpleados();
        mostrarForm = false;
        mensaje = "Empleado guardado correctamente.";
    }

    private void EditarEmpleado(Empleado emp)
    {
        empleadoEditando = new Empleado
        {
            Id = emp.Id,
            CodigoEmpleado = emp.CodigoEmpleado,
            Nombre = emp.Nombre,
            DUI = emp.DUI,
            Departamento = emp.Departamento,
            Cargo = emp.Cargo,
            Genero = emp.Genero,
            Correo = emp.Correo,
            Telefono = emp.Telefono,
            Direccion = emp.Direccion,
            Salario = emp.Salario,
            FechaIngreso = emp.FechaIngreso,
            FechaNacimiento = emp.FechaNacimiento,
            TipoContrato = emp.TipoContrato,
            CargoAcademico = emp.CargoAcademico,
            HoraEntrada = emp.HoraEntrada,
            HoraSalida = emp.HoraSalida,
            HoraEntradaSabado = emp.HoraEntradaSabado,
            HoraSalidaSabado = emp.HoraSalidaSabado,
            TrabajaSabado = emp.TrabajaSabado,
            Activo = emp.Activo
        };
        mostrarForm = true;
        mensaje = string.Empty;
    }

    private async Task EliminarEmpleado(int id)
    {
        var emp = await DB.Empleados.FindAsync(id);
        if (emp != null)
        {
            emp.Activo = false;
            await DB.SaveChangesAsync();
            await CargarEmpleados();
        }
    }

    private void ArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        archivoSeleccionado = e.File;
        archivoListo = true;
        mensajeImport = $"Archivo seleccionado: {e.File.Name}. Presiona Procesar CSV.";
        StateHasChanged();
    }

    private async Task ProcesarArchivo()
    {
        if (archivoSeleccionado == null) return;

        importando = true;
        previstaImport.Clear();
        mensajeImport = "Procesando archivo...";
        StateHasChanged();

        try
        {
            using var streamOriginal = archivoSeleccionado.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memStream = new MemoryStream();
            await streamOriginal.CopyToAsync(memStream);
            memStream.Position = 0;

            previstaImport = ImportService.ParsearCsvEmpleados(memStream);

            mensajeImport = previstaImport.Count == 0
                ? "No se detectaron empleados. Verifica el formato del archivo."
                : $"Se detectaron {previstaImport.Count} empleados. Revisa la vista previa.";
        }
        catch (Exception ex)
        {
            mensajeImport = $"Error: {ex.Message}";
        }

        importando = false;
        archivoListo = false;
        StateHasChanged();
    }

    private async Task ConfirmarImportCsv()
    {
        int nuevos = 0;
        int reactivados = 0;
        int omitidos = 0;

        foreach (var emp in previstaImport)
        {
            // Buscar si existe incluyendo inactivos
            var existente = await DB.Empleados.FirstOrDefaultAsync(e =>
                e.DUI == emp.DUI || e.Nombre == emp.Nombre);

            if (existente == null)
            {
                DB.Empleados.Add(emp);
                nuevos++;
            }
            else if (!existente.Activo)
            {
                // Reactivar y actualizar datos
                existente.Activo = true;
                existente.Nombre = emp.Nombre;
                existente.DUI = emp.DUI;
                existente.Departamento = emp.Departamento;
                existente.Cargo = emp.Cargo;
                existente.Correo = emp.Correo;
                existente.Telefono = emp.Telefono;
                existente.Salario = emp.Salario;
                existente.TipoContrato = emp.TipoContrato;
                existente.FechaIngreso = emp.FechaIngreso;
                existente.FechaNacimiento = emp.FechaNacimiento;
                existente.CargoAcademico = emp.CargoAcademico;
                existente.Direccion = emp.Direccion;
                existente.Genero = emp.Genero;
                reactivados++;
            }
            else
            {
                omitidos++;
            }
        }

        await DB.SaveChangesAsync();
        await CargarEmpleados();
        previstaImport.Clear();
        mensajeImport = $"✓ {nuevos} nuevos, {reactivados} reactivados, {omitidos} ya existían.";
        StateHasChanged();
    }
}